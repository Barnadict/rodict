# rodict — environment variables template
# Copy this file to `.env` for local development and fill in real values.
# (`.env` — not `.env.local` — because the Prisma CLI reads `.env`, and Next.js
# reads it too. Both are gitignored; never commit real secrets — see .gitignore.)

# --- Database (added in Phase 1 / Task #4) ---
# We connect via Prisma's libSQL driver adapter, which serves BOTH a local
# SQLite file AND the hosted Turso target (Task #30) — only this URL changes.
# Local dev (SQLite file):  DATABASE_URL="file:./dev.db"
# Hosted (Turso/libSQL):    DATABASE_URL="libsql://<db>.turso.io"
#   ...with an auth token:  DATABASE_AUTH_TOKEN="<token>"   (wired up in Task #30)
DATABASE_URL="file:./dev.db"

# --- Public site config ---
NEXT_PUBLIC_SITE_NAME="rodict"
