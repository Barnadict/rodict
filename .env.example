# rodict — environment variables template
# Copy this file to `.env.local` for local development and fill in real values.
# Never commit `.env.local` or any file with real secrets (see .gitignore).

# --- Database (added in Phase 1 / Task #4) ---
# Local dev uses SQLite; hosted (Task #30) uses Neon Postgres or Turso.
# Example (SQLite):   DATABASE_URL="file:./dev.db"
# Example (Postgres): DATABASE_URL="postgresql://user:password@host/db?sslmode=require"
DATABASE_URL=

# --- Public site config ---
NEXT_PUBLIC_SITE_NAME="rodict"
